<script>
  document.addEventListener('DOMContentLoaded', function() {
    const toggleButtons = document.querySelectorAll('button[command="--toggle"]');
    
    toggleButtons.forEach(button => {
      const targetId = button.getAttribute('commandfor');
      const disclosure = document.getElementById(targetId);
      
      if (disclosure) {
        button.addEventListener('click', function() {
          const isHidden = disclosure.style.display === 'none' || !disclosure.style.display;
          disclosure.style.display = isHidden ? 'block' : 'none';
          button.setAttribute('aria-expanded', isHidden);
        });
      }
    });
  });
</script>

