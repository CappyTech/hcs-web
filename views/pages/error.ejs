<!doctype html>
<html lang="en" class="h-full">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body class="h-full bg-gradient-to-b from-gray-50 to-white antialiased">

    <div class="grid min-h-full grid-rows-[1fr_auto]">

      <main class="flex items-center justify-center px-6 lg:px-8">
        <div class="w-full max-w-md text-center">

          <h1 class="text-6xl font-extrabold tracking-tight text-brand-charcoal"><%= statusCode %></h1>

          <div class="mx-auto mt-6 h-px w-16 bg-gradient-to-r from-transparent via-brand-light to-transparent" aria-hidden="true"></div>

          <p class="mt-6 text-xl font-semibold text-brand-charcoal">Something went wrong</p>
          <pre class="mt-4 rounded-md bg-white/60 border border-gray-200 px-4 py-3 text-sm text-gray-600 overflow-x-auto text-left shadow-sm"><%= message %></pre>

          <div class="mt-8">
            <a href="/" class="inline-flex items-center rounded-lg bg-brand-maroon px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-maroon/90">
              Go back home
            </a>
          </div>

        </div>
      </main>

      <footer class="py-6 text-center text-xs text-gray-400">
        &copy; <%= new Date().getFullYear() %> <%= site.name %>
      </footer>

    </div>
  </body>
</html>
