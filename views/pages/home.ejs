<div class="relative isolate overflow-hidden bg-gradient-to-br from-slate-100 via-sky-200/80 to-light-100 min-h-screen">
  <div aria-hidden="true" class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -left-44 top-0 h-96 w-96 rounded-full bg-primary opacity-40 blur-3xl"></div>
    <div class="absolute right-0 top-16 h-96 w-96 rounded-full bg-accent opacity-35 blur-3xl"></div>
    <div class="absolute left-1/2 top-72 h-80 w-80 -translate-x-1/2 rounded-full bg-tertiary opacity-30 blur-3xl"></div>
    <div class="absolute left-0 top-[32rem] h-96 w-96 rounded-full bg-grey-300 opacity-25 blur-3xl"></div>
    <div class="absolute right-[-10%] top-[40rem] h-72 w-72 rounded-full bg-fuchsia-300 opacity-20 blur-3xl"></div>
    <div class="absolute inset-x-1/4 bottom-0 h-72 w-72 rounded-full bg-sky-300 opacity-25 blur(3xl)"></div>
  </div>

  <div id="carousel" class="relative w-11/12 max-w-7xl mx-auto overflow-hidden rounded-lg shadow-lg">
    <div id="carousel-inner" class="flex transition-transform duration-500 ease-in-out">
    <div class="carousel-slide flex-shrink-0 w-full">
      <img class="w-full h-192 object-cover" src="/images/holgersfotografie-garden-fence-326616_1920.jpg" alt="First slide">
    </div>
    <div class="carousel-slide flex-shrink-0 w-full">
      <img class="w-full h-192 object-cover" src="/images/mac231-leaf-4470075_1920.jpg" alt="Second slide">
    </div>
    <div class="carousel-slide flex-shrink-0 w-full">
      <img class="w-full h-192 object-cover" src="/images/arcaion-pavement-1696507_1920.jpg" alt="Third slide">
    </div>
  </div>
  <button id="prev" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-black bg-opacity-50 text-white p-2 rounded-full hover:bg-opacity-75">❮</button>
  <button id="next" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-black bg-opacity-50 text-white p-2 rounded-full hover:bg-opacity-75">❯</button>
  <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2">
    <button class="indicator w-3 h-3 bg-white bg-opacity-50 rounded-full" data-slide="0"></button>
    <button class="indicator w-3 h-3 bg-white bg-opacity-50 rounded-full" data-slide="1"></button>
    <button class="indicator w-3 h-3 bg-white bg-opacity-50 rounded-full" data-slide="2"></button>
  </div>
</div>

<script>
  const carouselInner = document.getElementById('carousel-inner');
  const indicators = document.querySelectorAll('.indicator');
  let currentIndex = 0;

  function updateCarousel() {
    carouselInner.style.transform = `translateX(-${currentIndex * 100}%)`;
    indicators.forEach((ind, i) => {
      ind.classList.toggle('bg-opacity-100', i === currentIndex);
      ind.classList.toggle('bg-opacity-50', i !== currentIndex);
    });
  }

  document.getElementById('next').addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % 3;
    updateCarousel();
  });

  document.getElementById('prev').addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + 3) % 3;
    updateCarousel();
  });

  indicators.forEach((ind, i) => {
    ind.addEventListener('click', () => {
      currentIndex = i;
      updateCarousel();
    });
  });

  // Auto-play
  setInterval(() => {
    currentIndex = (currentIndex + 1) % 3;
    updateCarousel();
  }, 10000); // Changed slide every 10 seconds

  updateCarousel();
</script>



