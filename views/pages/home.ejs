            </div>
        </div>

        <div class="card active" style="background-image:url('https://source.unsplash.com/402x600/?winter,village');">
            <div class="card-content">
                <h3>paving</h3>
            </div>
        </div>

        <div class="card" style="background-image:url('https://source.unsplash.com/403x600/?snow,city');">
            <div class="card-content">
                <h3>Fencing</h3>
            </div>
        </div>
        <div class="card" style="background-image:url('https://source.unsplash.com/404x600/?snow,forest');">
            <div class="card-content">
