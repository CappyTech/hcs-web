<div class="container">

    <div class="carousel-wrapper">
        <button class="nav left" onclick="move(-1)">❮</button>

        <div class="carousel" id="carousel">
            <div class="card" style="background-image:url('arcaion-pavement-1696507_1920.jpg')"></div>
            <div class="card" style="background-image:url('holgersfotografie-garden-fence-326616_1920.jpg')"></div>
            <div class="card" style="background-image:url('mac231-leaf-4470075_1920.jpg')"></div>
            <div class="card" style="background-image:url('pexels-nicomarinb-35016102.jpg')"></div>
            <div class="card" style="background-image:url('https://source.unsplash.com/404x600/?forest,snow')"></div>
        </div>

        <button class="nav right" onclick="move(1)">❯</button>
    </div>

</div>

<style>
.container {
    width: 100%;
    max-width: 1100px;
    margin: auto;
}

body {
    background: #111;
}

/* FULL HEIGHT AREA FOR BUTTONS */
.carousel-wrapper {
    position: relative;
    overflow: hidden;
    height: 400px;
    display: flex;
    align-items: center;
}

/* CENTER TRACK */
.carousel {
    display: flex;
    gap: 20px;
    transition: transform 0.5s ease;
}

/* CARDS */
.card {
    flex: 0 0 220px;
    height: 320px;
    border-radius: 20px;
    background-size: cover;
    background-position: center;
    opacity: 0.6;
    transition: transform 0.4s, opacity 0.4s;
}

.card.active {
    transform: scale(1.2);
    opacity: 1;
}

/* BUTTONS FIXED TO SIDES */
.nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    background: rgba(128, 128, 128, 0.6);
    border: none;
    color: white;
    font-size: 26px;
    cursor: pointer;
    border-radius: 50%;
    z-index: 20;
}

.nav.left {
    left: 0;
}

.nav.right {
    right: 0;
}

.nav:hover {
    background: rgba(255,255,255,0.3);
}
</style>

<script>
const carousel = document.getElementById('carousel');

// duplicate for infinite loop
carousel.innerHTML =
    carousel.innerHTML +
    carousel.innerHTML +
    carousel.innerHTML;

const cards = document.querySelectorAll('.card');

const total = cards.length;
const visibleSet = total / 3;

let index = visibleSet;

const cardWidth = 240;

function update() {
    cards.forEach((card, i) => {
        card.classList.toggle('active', i === index);
    });

    const containerWidth = carousel.parentElement.offsetWidth;
    const offset = containerWidth / 2 - cardWidth / 2;

    carousel.style.transform =
        `translateX(${offset - index * cardWidth}px)`;
}

function move(dir) {
    index += dir;
    update();
}

carousel.addEventListener('transitionend', () => {
    if (index >= visibleSet * 2) {
        carousel.style.transition = 'none';
        index = visibleSet;
        update();
        requestAnimationFrame(() => {
            carousel.style.transition = 'transform 0.5s ease';
        });
    }

    if (index < visibleSet) {
        carousel.style.transition = 'none';
        index = visibleSet * 2 - 1;
        update();
        requestAnimationFrame(() => {
            carousel.style.transition = 'transform 0.5s ease';
        });
    }
});

// auto slide
setInterval(() => {
    move(1);
}, 3000);

update();
</script>