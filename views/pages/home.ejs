</div>

<style>
.container {
    width: 90%;
    max-width: 1000px;
    margin: auto;
    text-align: center;
    color: white;
    font-family: Arial, sans-serif;
}

body {
    background: #111;
}

.carousel-wrapper {
    position: relative;
}

h2 {
    margin-bottom: 20px;
    opacity: 0.8;
}

.carousel {
    display: flex;
    overflow: hidden;
    gap: 20px;
    padding: 20px;
}

.card {
    flex: 0 0 200px;
    height: 300px;
    border-radius: 20px;
    background-size: cover;
    background-position: center;
    position: relative;
    transition: transform 0.4s ease, opacity 0.4s ease;
    opacity: 0.6;
}

.card.active {
    transform: scale(1.2);
    opacity: 1;
}

.card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
    border-radius: 20px;
}

.card-content {
    position: absolute;
    bottom: 15px;
    left: 15px;
    z-index: 2;
}

.nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    font-size: 24px;
    padding: 10px;
    cursor: pointer;
    border-radius: 50%;
    z-index: 10;
}

.nav.left { left: 0; }
.nav.right { right: 0; }

.nav:hover {
    background: rgba(255,255,255,0.4);
}
</style>

<script>
const carousel = document.getElementById('carousel');
const cards = document.querySelectorAll('.card');

let index = 2; // start centered

function updateActive() {
    cards.forEach((card, i) => {
        card.classList.toggle('active', i === index);
    });

    const offset = (cards[0].offsetWidth + 20) * index;
    carousel.style.transform = `translateX(calc(50% - ${offset}px - 100px))`;
}

function scrollCarousel(direction) {
    index += direction;

    if (index < 0) index = cards.length - 1;
    if (index >= cards.length) index = 0;

    updateActive();
}

// Auto slide every 3 seconds
setInterval(() => {
    scrollCarousel(1);
}, 3000);

// Initial position
updateActive();
</script>