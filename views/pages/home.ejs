<div class="relative isolate overflow-hidden bg-white">
  
  <div id="carousel" class="relative w-11/12 max-w-7xl mx-auto overflow-hidden rounded-lg">
    <div id="carousel-inner" class="flex transition-transform duration-500 ease-in-out">
    <div class="carousel-slide flex-shrink-0 w-full">
      <img class="w-auto h-50% object-cover" src="/images/fence.jpeg" alt="First slide">
    </div>
    <div class="carousel-slide flex-shrink-0 w-full">
      <img class="w-auto h-50% object-cover" src="/images/gate 1.jpeg" alt="Second slide">
    </div>
    <div class="carousel-slide flex-shrink-0 w-full">
      <img class="w-auto h-50% object-cover" src="/images/fence 2.jpeg" alt="Third slide"> 
    </div>
  </div>
  <button id="prev" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-gray-300 bg-opacity-50 text-black p-2 rounded-full hover:bg-opacity-75">❮</button>
  <button id="next" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-gray-300 bg-opacity-50 text-black p-2 rounded-full hover:bg-opacity-75">❯</button>
  <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2">
    <button class="indicator w-3 h-3 bg-white bg-opacity-50 rounded-full" data-slide="0"></button>
    <button class="indicator w-3 h-3 bg-white bg-opacity-50 rounded-full" data-slide="1"></button>
    <button class="indicator w-3 h-3 bg-white bg-opacity-50 rounded-full" data-slide="2"></button>
  </div>
</div>

<script>
  const carouselInner = document.getElementById('carousel-inner');
  const indicators = document.querySelectorAll('.indicator');
  let currentIndex = 0;

  function updateCarousel() {
    carouselInner.style.transform = `translateX(-${currentIndex * 100}%)`;
    indicators.forEach((ind, i) => {
      ind.classList.toggle('bg-opacity-100', i === currentIndex);
      ind.classList.toggle('bg-opacity-50', i !== currentIndex);
    });
  }

  document.getElementById('next').addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % 3;
    updateCarousel();
  });

  document.getElementById('prev').addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + 3) % 3;
    updateCarousel();
  });

  indicators.forEach((ind, i) => {
    ind.addEventListener('click', () => {
      currentIndex = i;
      updateCarousel();
    });
  });

  // Auto-play
  setInterval(() => {
    currentIndex = (currentIndex + 1) % 3;
    updateCarousel();
  }, 10000); // Changed slide every 10 seconds

  updateCarousel();
</script>



