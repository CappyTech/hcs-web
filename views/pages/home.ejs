<script>
  const testimonialSlider = document.getElementById('testimonial-slider');
  const testimonialIndicators = document.querySelectorAll('.testimonial-indicator');
  const testimonialCount = testimonialIndicators.length;
  let testimonialIndex = 0;

  function updateTestimonialSlider() {
    testimonialSlider.style.transform = `translateX(-${testimonialIndex * 100}%)`;
    testimonialIndicators.forEach((indicator, index) => {
      indicator.classList.toggle('bg-gray-900', index === testimonialIndex);
      indicator.classList.toggle('bg-gray-300', index !== testimonialIndex);
    });
  }

  document.getElementById('testimonial-next').addEventListener('click', () => {
    testimonialIndex = (testimonialIndex + 1) % testimonialCount;
    updateTestimonialSlider();
  });

  document.getElementById('testimonial-prev').addEventListener('click', () => {
    testimonialIndex = (testimonialIndex - 1 + testimonialCount) % testimonialCount;
    updateTestimonialSlider();
  });

  testimonialIndicators.forEach((indicator) => {
    indicator.addEventListener('click', () => {
      testimonialIndex = Number(indicator.dataset.index);
      updateTestimonialSlider();
    });
  });

  setInterval(() => {
    testimonialIndex = (testimonialIndex + 1) % testimonialCount;
    updateTestimonialSlider();
  }, 10000);

  updateTestimonialSlider();
</script>

