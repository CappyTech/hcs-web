<!doctype html>
<html lang="en" class="h-full">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body class="h-full bg-gradient-to-b from-gray-50 to-white antialiased">

    <div class="grid min-h-full grid-rows-[auto_1fr_auto]">

      <%- include('../partials/header') %>

      <main class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
        <h1 class="text-3xl font-extrabold tracking-tight text-brand-charcoal sm:text-4xl">Contact</h1>
        <p class="mt-4 text-base leading-7 text-gray-500">Send us a message using the form below.</p>

        <% if (sent) { %>
          <div class="mt-4 rounded-lg border border-green-200 bg-green-50 p-4 text-sm text-green-800">
            Message sent (demo). In a real app you would email/store it.
          </div>
        <% } %>

        <% if (error) { %>
          <div class="mt-4 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-800">
            <strong class="font-semibold">Form error:</strong> <%= error %>
          </div>
        <% } %>

        <form class="mt-8 space-y-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm" method="POST" action="/contact">
          <div>
            <label for="name" class="block text-sm font-semibold text-brand-charcoal">Name</label>
            <input
              id="name"
              class="mt-2 block w-full rounded-lg border border-gray-300 px-3.5 py-2 text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-brand-maroon focus:ring-2 focus:ring-brand-maroon/20 focus:outline-none sm:text-sm"
              name="name"
              type="text"
              value="<%= form?.name || '' %>"
              required
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-brand-charcoal">Email</label>
            <input
              id="email"
              class="mt-2 block w-full rounded-lg border border-gray-300 px-3.5 py-2 text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-brand-maroon focus:ring-2 focus:ring-brand-maroon/20 focus:outline-none sm:text-sm"
              name="email"
              type="email"
              value="<%= form?.email || '' %>"
              required
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-brand-charcoal">Message</label>
            <textarea
              id="message"
              class="mt-2 block w-full rounded-lg border border-gray-300 px-3.5 py-2 text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-brand-maroon focus:ring-2 focus:ring-brand-maroon/20 focus:outline-none sm:text-sm"
              name="message"
              rows="6"
              required
            ><%= form?.message || '' %></textarea>
          </div>

          <button
            type="submit"
            class="inline-flex items-center rounded-lg bg-brand-maroon px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-maroon/90 focus:outline-none focus:ring-2 focus:ring-brand-maroon/20"
          >
            Send
          </button>
        </form>

        <section class="mt-8 rounded-xl border border-gray-200 bg-white shadow-sm">
          <div class="p-6">
            <h2 class="text-lg font-semibold text-brand-charcoal">Contact details</h2>
            <p class="mt-2 text-sm text-gray-500">
              Phone: <a class="text-brand-maroon hover:underline" href="tel:<%= site.phone %>"><%= site.phone %></a><br />
              Email: <a class="text-brand-maroon hover:underline" href="mailto:<%= site.email %>"><%= site.email %></a>
            </p>
          </div>
        </section>
      </main>

      <footer class="py-6 text-center text-xs text-gray-400">
        &copy; <span id="js-year"></span> <%= site.name %>
      </footer>

    </div>

    <script src="/js/site.js" defer></script>
  </body>
</html>
