<main class="flex items-center justify-center px-6 lg:px-8">
  <div class="w-full max-w-md text-center">
    <h1 class="text-6xl font-extrabold tracking-tight text-brand-charcoal">
      404
    </h1>

    <div
      class="mx-auto mt-6 h-px w-16 bg-gradient-to-r from-transparent via-brand-light to-transparent"
      aria-hidden="true"
    ></div>

    <p class="mt-6 text-xl font-semibold text-brand-charcoal">Page Not Found</p>
    <p class="mt-3 text-base leading-7 text-gray-500">
      The page
      <span class="font-medium text-brand-maroon"><%= requestedPath %></span>
      does not exist.
    </p>

    <div class="mt-8">
      <a
        href="/"
        class="inline-flex items-center rounded-lg bg-brand-maroon px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-maroon/90"
      >
        Go back home
      </a>
    </div>
  </div>
</main>
