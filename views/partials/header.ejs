<% /* views/partials/header.ejs Site header + navigation using Tailwind CSS. We use page.activeNav to highlight the current link. */ %>
<%
  var activeNav = (typeof page !== 'undefined' && page && page.activeNav) ? page.activeNav : '';
  function navClass(href) {
    var isActive = activeNav === href;
    return 'inline-flex items-center border-b-2 px-1 pt-1 text-sm font-medium ' +
      (isActive
        ? 'border-accent text-primary'
        : 'border-grey text-brand-charcoal hover:border-accent hover:text-primary');
  }
%>

<nav class="relative bg-white shadow-sm">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center py-4">

      <div class="flex items-center">
        <a href="/">
          <span class="sr-only"><%= site.name %></span>
          <img
            src="https://heroncs.co.uk/images/HCS-Logo-v5.png"
            alt="<%= site.name %>"
            class="h-50 w-auto"
          />
        </a>
      </div>

      <div class="flex space-x-8">

        <a href="/" class="<%= navClass('/') %>" <%= activeNav === '/' ? 'aria-current="page"' : '' %>>
          Home
        </a>

        <a href="/about" class="<%= navClass('/about') %>" <%= activeNav === '/about' ? 'aria-current="page"' : '' %>>
          About
        </a>

        <a href="/services" class="<%= navClass('/services') %>" <%= activeNav === '/services' ? 'aria-current="page"' : '' %>>
          Services
        </a>

        <a href="/contact" class="<%= navClass('/contact') %>" <%= activeNav === '/contact' ? 'aria-current="page"' : '' %>>
          Contact
        </a>

      </div>
    </div>
  </div>
</nav>